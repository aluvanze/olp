# Copy this file to .env and fill in your real values.
# Do NOT commit .env to git. Use .env only on the server / your machine.

# Database (required)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grade10_lms
DB_USER=postgres
DB_PASSWORD=your_password_here

# App
PORT=3000
NODE_ENV=production

# Auth (required for login)
JWT_SECRET=your_long_random_secret_here
JWT_EXPIRES_IN=7d

# Optional: if app is behind a different frontend URL
# FRONTEND_URL=https://your-domain.com

# Optional: email (for notifications)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=Grade 10 LMS
